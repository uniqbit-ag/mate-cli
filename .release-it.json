{
  "$schema": "https://unpkg.com/release-it@20/schema/release-it.json",
  "git": {
    "commitMessage": "chore(release): ${version}",
    "tagName": "${version}",
    "tagExclude": "*-*",
    "requireBranch": "main",
    "requireCleanWorkingDir": true,
    "requireUpstream": true
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "hooks": {
    "before:init": [
      "bun run test",
      "bun run typecheck"
    ],
    "after:bump": [
      "bun scripts/sync-release-versions.ts"
    ]
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "header": "# Changelog",
      "infile": "CHANGELOG.md",
      "preset": {
        "name": "conventionalcommits"
      }
    }
  }
}
