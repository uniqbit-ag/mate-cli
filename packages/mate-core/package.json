    "react-doctor": "0.8.1",
    "semver": "^7.8.5",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/semver": "^7.7.1"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "bun@1.3.14"
