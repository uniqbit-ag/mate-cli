---
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Mate Docs",
  description = "Companion-first docs for Mate: setup, launch flow, concepts, capabilities, and CLI reference.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <ClientRouter />
  </head>
  <body
    class="flex min-h-screen flex-col bg-fd-background text-fd-foreground"
    transition:persist
    transition:animate="none"
    transition:name="page-layout"
  >
    <slot />
  </body>
</html>
