---
import { render, type CollectionEntry } from "astro:content";
import type { TOCItemType } from "fumadocs-core/toc";
import defaultMdxComponents from "fumadocs-ui/mdx";
import { Docs } from "@/components/docs";
import Layout from "@/components/layout.astro";
import { source } from "@/lib/source";
import "@/styles/global.css";

interface Props {
  page: CollectionEntry<"docs">;
}

export async function getStaticPaths() {
  return source.getPages().map((page) => ({
    params: { slug: page.slugs.length > 0 ? page.slugs.join("/") : undefined },
    props: { page: page.data._raw },
  }));
}

const { page } = Astro.props;
const { Content, headings } = await render(page);
const toc: TOCItemType[] = headings.map((heading) => ({
  depth: heading.depth,
  title: heading.text,
  url: `#${heading.slug}`,
}));
---

<Layout title={`${page.data.title} | Mate Docs`} description={page.data.description}>
  <Docs
    tree={source.getPageTree()}
    pathname={Astro.url.pathname}
    params={Astro.params}
    title={page.data.title}
    description={page.data.description}
    page={{ toc, full: page.data.full }}
    client:load
  >
    <Content components={{ ...defaultMdxComponents }} />
  </Docs>
</Layout>
