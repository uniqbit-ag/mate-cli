{
  "name": "@uniqbit/mate",
  "version": "0.14.2-canary.0",
  "license": "MIT",
  "bin": {
    "mate": "src/cli-bootstrap.cjs"
  },
  "files": [
    "src/",
    "wrappers/"
  ],
  "type": "module",
  "exports": {
    ".": "./src/lib/orchestrator/launcher.ts",
    "./docs/reference": "./src/docs/reference.ts"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "bun scripts/prepare.ts",
    "release": "release-it --config ../../.release-it.json && ../../publish.sh latest",
    "release:canary": "release-it --config ../../.release-it.canary.json --preRelease=canary && ../../publish.sh canary",
    "release:dry-run": "release-it --config ../../.release-it.json --dry-run --no-git.push",
    "test": "CI=1 bun test",
    "test:ci": "bun scripts/generate-test-reports.ts --junit",
    "test:coverage": "bun scripts/generate-test-reports.ts",
    "typecheck": "bunx tsc --noEmit -p ../../tsconfig.json && bunx tsc --noEmit -p src/templates/tsconfig.json",
    "lint": "oxlint src/",
    "lint:fix": "oxlint src/ --fix",
    "format": "oxfmt src/",
    "format:check": "oxfmt src/ --check"
  },
  "dependencies": {
    "headroom-ai": "^0.22.4",
    "ink": "^7.1.0",
    "react": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.18.3",
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "release-it": "^20.2.1",
    "typescript": "latest"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "bun@1.3.14"
}
